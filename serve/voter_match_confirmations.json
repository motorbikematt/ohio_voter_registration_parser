{
  "_meta": {
    "description": "Durable, human-owned ledger of filer->voter match confirmations. This file is the SOURCE OF TRUTH for verification and is NEVER regenerated by the pipeline. match_to_voters.py JOINS it into serve/partisan_profiles.json as a read-only `verification` projection; do not hand-edit the projection (a rebuild wipes it) -- edit here. Git history is the audit log; sign ledger commits.",
    "schema_version": 1,
    "states": {
      "unverified": "default when no entry exists for a match_key",
      "confirmed": "a human verified this filer IS this sos_voterid; stays `current` until the bound voter record changes (binding_hash), then auto-flags `stale`",
      "rejected": "a human verified this match is WRONG; the profile keeps the auto-match but is flagged needs_review",
      "corrected": "a human supplied the right voter; set corrected_sos_voterid and the build re-points the profile to it"
    },
    "entry_shape": {
      "match_key": "entity_type|section/key-or-precinct|name (see match_to_voters.match_key)",
      "sos_voterid": "the voterid this confirmation pertains to (the auto-matched id)",
      "state": "confirmed | rejected | corrected",
      "corrected_sos_voterid": "for state=corrected: the right voterid (else null)",
      "verified_by": "confirmer identity (ties to ROSTER_TOKEN auth later)",
      "verified_date": "YYYY-MM-DD",
      "basis": {
        "dob_match": false,
        "jurisdiction_consistent": false,
        "address_match": false
      },
      "binding_hash": "match_to_voters.binding_hash of the voter at confirmation time"
    }
  },
