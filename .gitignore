# ─── Python ───────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.DS_Store
.venv/
venv/
env/

# ─── Voter data files (never commit raw voter records) ────
# The source/ directory holds raw and decompressed voter files
# from the Ohio SOS.  These contain PII, are very large, and
# are re-downloadable on demand via ohio_voter_pipeline.py.
source/

# ─── Analysis outputs ─────────────────────────────────────
# Excel workbooks and CSVs produced by the analysis scripts.
# EXCEPTION: We track precinct metadata as it contains no PII.
*.xlsx
*.csv
!source/precinct_keys/*.csv

# ─── Project Specific Artifacts ───────────────────────────
working/
collision_report.md
.ipynb_checkpoints/
*.bat
*.ps1
*.code-workspace

# ─── Raw voter file formats ────────────────────────────────
# The decompressed state voter files are plain .txt.  This rule
# is intentionally broad — it excludes ALL .txt files, not just
# voter data — as an extra conservative guard against accidentally
# uploading large government data files if the source/ rule above
# is ever bypassed.  Any plain-text documentation in this repo
# should use .md instead.
*.txt

# ─── Download tracking ────────────────────────────────────
# download_manifest.json records local paths and Last-Modified
# timestamps that are machine-specific — not useful in git.
download_manifest.json

# ─── Logs ─────────────────────────────────────────────────
logs/

# ─── UNC target list exports (PII — never commit) ─────────
UNC_Exports/

# ─── Instructions
JUPYTER_QUICKSTART.md
RUN_LOCALLY.md
*.PDF*.png
*.PNG
LEGEND_EXPLORATION.md
LEGEND_AND_TOOLTIP_STRATEGY.md
CHARTJS_PLUGINS_RESEARCH.md
GEMINI_backup_20260509_2355.md
.gitignore
GEMINI.md
HANDOFF_OPUS_PASS_B.md
